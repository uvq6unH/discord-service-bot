{
  "name": "discord-service-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "prod": "pm2 start pm2.config.cjs",
    "prod:stop": "pm2 stop discord-service-bot",
    "prod:restart": "pm2 restart discord-service-bot",
    "prod:logs": "pm2 logs discord-service-bot",
    "prod:status": "pm2 status",
    "keep-alive": "bash keep-alive.sh",
    "check": "node --check src/index.js && node --check src/bot.js && node --check src/server.js && node --check src/configStore.js"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.3.0",
    "libsodium-wrappers": "^0.8.4",
    "play-dl": "^1.9.7"
  }
}
