DISCORD_TOKEN=your_discord_bot_token
PORT=3000
CONFIG_PATH=./data/configs.json
STATE_PATH=./data/state.json

# Discord OAuth2 (lấy từ Discord Developer Portal > OAuth2)
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_application_client_secret
# URL callback phải khớp với Redirects trong Developer Portal
# Local:  http://localhost:3000/auth/callback
# Render: https://your-app.onrender.com/auth/callback
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# Secret ngẫu nhiên để ký session cookie — đặt chuỗi dài bất kỳ
SESSION_SECRET=change_this_to_a_long_random_string
