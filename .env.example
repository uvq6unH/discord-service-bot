# Core
DISCORD_TOKEN=your_discord_bot_token
PORT=3000
NODE_ENV=development
CONFIG_PATH=./data/configs.json
STATE_PATH=./data/state.json

# Discord OAuth2 dashboard auth
# Local redirect:  http://localhost:3000/auth/callback
# Render redirect: https://your-app.onrender.com/auth/callback
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_application_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# Local dev only: allow unauthenticated dashboard when OAuth env vars are omitted.
# Never enable on Render/production.
ALLOW_DEV_AUTH=false
DEV_USER_ID=
DEV_USERNAME=Dev User

# Riot API
RIOT_API_KEY=
TFT_API_KEY=

# Persistent state on Render/free hosts
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Bot runtime options
KEEPALIVE_CHANNEL_ID=
DAILY_RESET_UTC_OFFSET_MINUTES=420
COMMAND_COOLDOWN_MS=3000
RIOT_COMMAND_COOLDOWN_MS=15000
GAME_COMMAND_COOLDOWN_MS=5000
