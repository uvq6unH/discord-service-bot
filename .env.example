# =============================================================================
# BOT SERVICE — src/index.bot.js
# Render vars: COMMAND_COOLDOWN_MS, DAILY_RESET_UTC_OFFSET_MINUTES,
#              DISCORD_CLIENT_ID, DISCORD_TOKEN, GAME_COMMAND_COOLDOWN_MS,
#              LAVALINK_HOST, LAVALINK_PASSWORD, LAVALINK_PORT, LAVALINK_SECURE,
#              NODE_ENV, PORT, RIOT_API_KEY, RIOT_COMMAND_COOLDOWN_MS,
#              UPSTASH_REDIS_REST_TOKEN, UPSTASH_REDIS_REST_URL
# =============================================================================

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=                          # Bot token — Discord Developer Portal > Bot
DISCORD_CLIENT_ID=                      # Application ID — cần để register slash commands

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=                 # https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=               # token từ Upstash console
UPSTASH_EMAIL=                          # Email tài khoản Upstash (Developer API)
UPSTASH_API_KEY=                        # Key Developer API từ Upstash console

# ── Riot API (optional) ───────────────────────────────────────────────────────
RIOT_API_KEY=                           # RGAPI-xxx — dùng cho cả /lol lẫn /tft nếu TFT_API_KEY trống
TFT_API_KEY=                            # Key riêng cho TFT — để trống = dùng chung RIOT_API_KEY

# ── Lavalink (optional — bỏ qua nếu không dùng music) ───────────────────────
LAVALINK_HOST=                          # host Lavalink server (Railway / Fly.io)
LAVALINK_PORT=80
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false                   # true nếu WSS/HTTPS

# ── Cooldowns (optional — có default) ────────────────────────────────────────
COMMAND_COOLDOWN_MS=3000                # default 3000ms
RIOT_COMMAND_COOLDOWN_MS=15000          # default 15000ms
GAME_COMMAND_COOLDOWN_MS=5000           # default 5000ms

# ── Bot Status & Activity (optional) ──────────────────────────────────────────
BOT_STATUS_TEXT=                        # Trạng thái hiển thị (ví dụ: /help | {guilds} servers)
BOT_STATUS_TYPE=                        # Kiểu hiển thị (PLAYING, WATCHING, LISTENING, STREAMING, COMPETING)
BOT_STATUS_STREAM_URL=                  # Twitch link nếu dùng STREAMING type (ví dụ: https://www.twitch.tv/discord)

# ── Economy (optional) ────────────────────────────────────────────────────────
DAILY_RESET_UTC_OFFSET_MINUTES=420      # Offset phút so với UTC cho daily reset — default 420 (UTC+7)

# ── Runtime (optional) ───────────────────────────────────────────────────────
PORT=10000                              # Render tự inject — thường không cần set
NODE_ENV=production


# =============================================================================
# DASHBOARD SERVICE — src/index.server.js
# Render vars: CONFIG_PATH, DISCORD_CLIENT_ID, DISCORD_CLIENT_SECRET,
#              DISCORD_REDIRECT_URI, NODE_ENV, PORT, SESSION_SECRET,
#              STATE_PATH, UPSTASH_REDIS_REST_TOKEN, UPSTASH_REDIS_REST_URL
# =============================================================================

# ── Discord OAuth2 ────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=                      # Application ID — giống với bot
DISCORD_CLIENT_SECRET=                  # Client Secret — OAuth2 tab trong Developer Portal
DISCORD_REDIRECT_URI=                   # https://your-dashboard.onrender.com/auth/callback
                                        # Phải match chính xác URI đã đăng ký trong Discord app

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=                         # Random string ≥32 ký tự — openssl rand -base64 32

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=                 # Cùng instance với bot
UPSTASH_REDIS_REST_TOKEN=

# ── Local fallback paths (optional — Redis được ưu tiên trên production) ─────
CONFIG_PATH=./data/configs.json         # Chỉ dùng khi không có Redis
STATE_PATH=./data/state.json            # Chỉ dùng khi không có Redis

# ── Uptime & Telemetry (optional) ─────────────────────────────────────────────
UPTIMEROBOT_API_KEY=                    # API Key từ UptimeRobot (hỗ trợ nhiều key phân tách bằng dấu phẩy)
UPSTASH_MONTHLY_COMMANDS=0              # Mốc bù tổng số lệnh đầu tháng (default 0)
UPSTASH_MONTHLY_READS=0                 # Mốc bù tổng số reads đầu tháng (default 0)
UPSTASH_MONTHLY_WRITES=0                # Mốc bù tổng số writes đầu tháng (default 0)


# ── Runtime (optional) ────────────────────────────────────────────────────────
PORT=10001                              # Render tự inject — thường không cần set
NODE_ENV=production

# ── Dev only — KHÔNG set trên production ─────────────────────────────────────
# ALLOW_DEV_AUTH=true                   # Bỏ qua Discord OAuth (local dev only)
# DEV_USER_ID=123456789                 # User ID giả khi ALLOW_DEV_AUTH=true
# DEV_USERNAME=Dev User                 # Username giả khi ALLOW_DEV_AUTH=true
